# Supabase (cloud Postgres) — preferred for local/dev without Docker
# Project: InvestmentDashboard (us-east-2)
# Dashboard → Project Settings → Database → copy password, then run:
#   .\scripts\link-supabase.ps1
#
# Prisma runtime (transaction pooler, port 6543). Host may be aws-0- or aws-1- depending on project.
# Prefer copying exact URIs from Dashboard -> Connect -> ORM -> Prisma if unsure.
DATABASE_URL="postgresql://postgres.yqugkmikyfpmgjawebfr:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Prisma migrations / seed (session mode, port 5432)
DIRECT_URL="postgresql://postgres.yqugkmikyfpmgjawebfr:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

SUPABASE_URL="https://yqugkmikyfpmgjawebfr.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://yqugkmikyfpmgjawebfr.supabase.co"
# Optional public anon key (only if you add a Supabase JS client later)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Required for NextAuth sessions
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# AI Insights (OpenRouter)
OPENROUTER_API_KEY=""
ADMIN_EMAILS="your-admin@example.com"

# YouTube Analysis (Data API v3 + ingest)
YOUTUBE_API_KEY=""
YOUTUBE_CHANNELS_FILE="conf/youtube_channels.json"
YOUTUBE_POLL_SINCE_DAYS="2"
YOUTUBE_CACHE_DIR="data"
YOUTUBE_RATE_LIMIT_PER_MIN="30"
# Optional override for summarization model (defaults to deepseek/deepseek-chat with fallbacks)
# YOUTUBE_SUMMARY_MODEL="deepseek/deepseek-chat"

# Webull OpenAPI (admin broker + hybrid quotes; never commit real keys)
WEBULL_APP_KEY=""
WEBULL_APP_SECRET=""
WEBULL_REGION_ID="us"
WEBULL_ENVIRONMENT="prod"
WEBULL_RATE_LIMIT_PER_MIN="30"
WEBULL_TOKEN_DIR="conf"

# Optional local Docker Postgres (only if you are NOT using Supabase)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/market_intel"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/market_intel"
