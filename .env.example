# Local development (default) — use with: docker compose up -d
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/market_intel"

# Required for NextAuth sessions
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Abacus-hosted Postgres (only works from their network / active project)
