# Local development (default) — use with: docker compose up -d
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/market_intel"

# Required for NextAuth sessions
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# AI Insights (OpenRouter)
OPENROUTER_API_KEY=""
ADMIN_EMAILS="your-admin@example.com"

# YouTube Analysis (Data API v3 + ingest)
YOUTUBE_API_KEY=""
YOUTUBE_CHANNELS_FILE="conf/youtube_channels.json"
YOUTUBE_POLL_SINCE_DAYS="2"
YOUTUBE_CACHE_DIR="data"
YOUTUBE_RATE_LIMIT_PER_MIN="30"
# Optional override for summarization model (defaults to deepseek/deepseek-chat with fallbacks)
# YOUTUBE_SUMMARY_MODEL="deepseek/deepseek-chat"

# Webull OpenAPI (admin broker + hybrid quotes; never commit real keys)
WEBULL_APP_KEY=""
WEBULL_APP_SECRET=""
WEBULL_REGION_ID="us"
WEBULL_ENVIRONMENT="prod"
WEBULL_RATE_LIMIT_PER_MIN="30"
WEBULL_TOKEN_DIR="conf"

# Optional: Abacus-hosted Postgres (only works from their network / active project)
# DATABASE_URL="postgresql://USER:PASSWORD@db-XXXX.hosteddb.reai.io:5432/DBNAME?connect_timeout=15"
